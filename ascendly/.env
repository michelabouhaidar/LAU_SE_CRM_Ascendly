NODE_ENV=development
DISABLE_RATE_LIMIT=true

POSTGRES_DB=ascendly
POSTGRES_USER=ascendly_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://ascendly_user:change_me_in_production@db:5432/ascendly

ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@ascendly.io
ADMIN_PASSWORD=Change_Me_On_First_Login!
VITE_ADMIN_EMAIL=admin@ascendly.io

JWT_SECRET=generate_a_64_byte_hex_string_here
JWT_EXPIRES_IN=8h

BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
LOGIN_RATE_LIMIT_MAX=5

CORS_ORIGIN=https://ascendly.io

DOMAIN=ascendly.io
ACME_EMAIL=admin@ascendly.io

VITE_API_URL=https://ascendly.io/api
